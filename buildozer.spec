[app]
title = VibeAI
package.name = vibeai
package.domain = org.vibeai
source.dir = .
source.include_exts = py,png,jpg,kv,atlas,mp3
version = 0.1
requirements = python3,kivy,gtts
orientation = portrait
fullscreen = 1
android.permissions = RECORD_AUDIO, INTERNET, WRITE_EXTERNAL_STORAGE, READ_EXTERNAL_STORAGE
android.api = 33
android.minapi = 21
android.archs = arm64-v4a, armeabi-v7a
